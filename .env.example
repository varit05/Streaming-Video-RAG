# ─────────────────────────────────────────────────────────────────────────────
# Streaming Video-RAG — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: openai | anthropic | ollama
LLM_PROVIDER=ollama

# Model name for openai / anthropic (ignored when using ollama)
LLM_MODEL=gpt-4o
# LLM_MODEL=claude-opus-4-6   # for anthropic

# Ollama (only needed if LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Whisper Transcription ─────────────────────────────────────────────────────
# Options: local | openai_api
WHISPER_MODE=local

# Local Whisper model size (tiny | base | small | medium | large | large-v2)
# Larger = more accurate but slower. "base" is a good starting point.
WHISPER_MODEL_SIZE=base

# ── Embeddings ────────────────────────────────────────────────────────────────
# Options: local | openai
# Use "local" for development, "openai" for better quality in production
EMBEDDING_MODE=local
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Vector Store ──────────────────────────────────────────────────────────────
# Options: chroma | qdrant
# Use "chroma" for local dev, "qdrant" for production
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma

# Qdrant (only needed if VECTOR_STORE_TYPE=qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=video_rag

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for dev, PostgreSQL for prod
DATABASE_URL=sqlite:///./data/video_rag.db
# DATABASE_URL=postgresql://user:password@localhost:5432/video_rag

# ── Storage Paths ─────────────────────────────────────────────────────────────
DATA_DIR=./data
AUDIO_DIR=./data/audio
TRANSCRIPT_DIR=./data/transcripts

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ── RAG Tuning ────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
CHUNK_DURATION_SECONDS=60
CHUNK_OVERLAP_SECONDS=15

# ── Live Stream ───────────────────────────────────────────────────────────────
LIVE_STREAM_SEGMENT_SECONDS=60

# ── UI ────────────────────────────────────────────────────────────────────────
UI_API_BASE_URL=http://localhost:8000
